# Use an official, lightweight Python runtime

FROM python:3.10-slim

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Install dependencies (Dockerfile is in the same folder as requirements.txt now!)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy everything from the backend/ folder into the container
COPY . .

EXPOSE 8000

# Run the Uvicorn server, referencing the internal path
CMD ["uvicorn", "api.gateway_v2:app", "--host", "0.0.0.0", "--port", "8000"]
